# Add these browser-safe values in Render Dashboard > Environment.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_PAYSTACK_PUBLIC_KEY=

# Add these server-only secrets in Render Dashboard > Environment.
# Never prefix server secrets with VITE_.
SUPABASE_SERVICE_ROLE_KEY=
# Optional. A stable 32+ character secret used to encrypt user-supplied keys.
# When omitted, the server derives encryption from SUPABASE_SERVICE_ROLE_KEY.
API_KEY_ENCRYPTION_KEY=
PAYSTACK_SECRET_KEY=
OPENAI_API_KEY=
TAVILY_API_KEY=
GROQ_API_KEY=
ALPHA_API_URL=/api/alpha
PUBLIC_APP_URL=https://alphatekx.name.ng

# Google Cloud OAuth web client. Enable Gmail API and register the callback exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://alphatekx.name.ng/auth/google/callback
# Optional separate signing secret for short-lived OAuth state values.
OAUTH_STATE_SECRET=

# Meta OAuth app. Add this exact URI under Facebook Login > Valid OAuth Redirect URIs.
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://alphatekx.name.ng/api/connectors/facebook/callback
